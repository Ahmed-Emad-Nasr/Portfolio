# Contact submission endpoint (required)
# Example: https://formspree.io/f/yourFormId
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# Telegram alerts (choose one approach)
# Recommended relay webhook (Make/Pipedream/custom relay)
NEXT_PUBLIC_TELEGRAM_WEBHOOK_URL=

# Direct bot mode (fallback when webhook is not used)
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_CHAT_ID=

# Optional anti-spam challenge in contact form
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
